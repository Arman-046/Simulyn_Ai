# -------------------------------------------------------------
# Simulyn Enterprise Environment Variables
# -------------------------------------------------------------

# PostgreSQL Database URL
# Uses the asyncpg driver. Change localhost to the docker container name (e.g., 'db') if running the backend in Docker.
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/simulyn"

# Fireworks AI API Key (Used for LLM Persona Extraction)
# Required for dynamic persona generation. If empty, the system falls back to a deterministic regex generator.
FIREWORKS_API_KEY="your_fireworks_api_key_here"

# Redis Configuration (Provisioned but currently unutilized by FastAPI)
REDIS_URL="redis://localhost:6379/0"

# Application Environment (development / production)
APP_ENV="development"

# Logging Level
LOG_LEVEL="INFO"

# Hardware Specifics (Optional)
# PYTORCH_DEVICE="cuda" # Force a specific PyTorch device (cuda, rocm, cpu). Auto-detected if omitted.
